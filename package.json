{
	"name": "lceda-decoupling-meow",
	"version": "0.9.17",
	"description": "去耦喵：一次为选中 IC 的多个电源网络生成可选主电容和逐引脚去耦电容",
	"author": "MeowKJ",
	"license": "Apache-2.0",
	"homepage": "https://github.com/MeowKJ/lceda-decoupling-meow",
	"engines": {
		"node": ">=20.17.0"
	},
	"scripts": {
		"compile": "rimraf ./dist/ && ts-node ./config/esbuild.prod.ts",
		"lint": "eslint",
		"fix": "eslint --fix",
		"test": "npm run compile && node --test tests/*.test.mjs",
		"check": "npm run lint && npm run test && npm run build",
		"build": "npm run compile && ts-node ./build/packaged.ts && node ./build/verify-package.mjs"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@jlceda/pro-api-types": "^0.3.4",
		"@types/fs-extra": "^11.0.4",
		"esbuild": "^0.24.2",
		"eslint": "^9.37.0",
		"fs-extra": "^11.3.0",
		"ignore": "^7.0.3",
		"jszip": "^3.10.1",
		"lint-staged": "^16.2.3",
		"rimraf": "^6.0.1",
		"simple-git-hooks": "^2.13.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
